# ╔═══════════════════════════════════════════════════════════════════════════════╗
# ║  HUMANLIKE AUTO-SURFING ENGINE — ENVIRONMENT CONFIGURATION v2.0            ║
# ║  Generated: 2026-03-04 | Based on: Bab 1-3 Probabilistic Models           ║
# ╠═══════════════════════════════════════════════════════════════════════════════╣
# ║                                                                             ║
# ║  BENCHMARK ANCHORS (Contentsquare 2021-2024, NNg, Omnisend, etracker):     ║
# ║    Bounce rate       = 47%    (all-industry average)                        ║
# ║    Pages/session     = 5      (Contentsquare)                              ║
# ║    Time on page      = 54s    (mean, Weibull distributed)                  ║
# ║    Scroll depth      = 56.8%  (average scroll rate)                        ║
# ║    Frustration       = 39.6%  (sessions with friction signals)             ║
# ║    Cookie reject     = 60%    (legal-compliant design)                     ║
# ║    Popup conversion  = 2.4%   (sweet spot at 6-10s delay)                 ║
# ║                                                                             ║
# ║  IMPORTANT: Mode 6 (Realistic Mix) uses all benchmark values as-is.        ║
# ║  Other modes override specific parameters for targeted behavior.            ║
# ║  Manual overrides in [FINE-TUNING] section apply ON TOP of mode defaults.  ║
# ║                                                                             ║
# ╚═══════════════════════════════════════════════════════════════════════════════╝


# ─────────────────────────────────────────────────────────────────────────────
#  SECTION 1: SURFING MODE SELECTOR
# ─────────────────────────────────────────────────────────────────────────────
#
#  ┌─────┬───────────────────┬──────────────────────────────────────────────┐
#  │ ID  │ Mode Name         │ Behavior                                     │
#  ├─────┼───────────────────┼──────────────────────────────────────────────┤
#  │  1  │ Manual            │ No auto-surfing. Human takes control.        │
#  │  2  │ High Bounce Rate  │ Quick exit. 1 page, 5-15s dwell.            │
#  │  3  │ Speed Reader      │ Fast scan. 2-3 pages, shallow scroll.       │
#  │  4  │ Natural Explorer  │ Balanced. 3-5 pages, moderate engagement.   │
#  │  5  │ Deep Reader       │ Thorough. 5-10+ pages, deep scroll, slow.   │
#  │  6  │ Realistic Mix     │ Statistical blend per Bab 1-3 benchmarks.   │
#  │     │   (RECOMMENDED)   │ 47% bounce, Weibull dwell, Markov scroll.   │
#  │  7  │ SEO Boost         │ Engagement-optimized. Low bounce, high CTR. │
#  └─────┴───────────────────┴──────────────────────────────────────────────┘
#
#  Mode 6 is the default and recommended mode for maximum realism.
#  It produces sessions statistically indistinguishable from real traffic.
#
SURFING_MODE=6


# ─────────────────────────────────────────────────────────────────────────────
#  SECTION 2: SESSION MANAGEMENT
# ─────────────────────────────────────────────────────────────────────────────

# Directory to store browser session profiles (cookies, localStorage, etc.)
SESSIONS_DIR=./sessions

# Minimum age (hours) for a profile to be considered "mature"
# Mature profiles have accumulated cookies and browsing history
# that make them appear more realistic to analytics platforms.
MATURE_PROFILE_AGE_HOURS=48

# Maximum concurrent browser sessions
MAX_CONCURRENT_SESSIONS=3

# Delay between launching consecutive sessions (seconds)
# Prevents burst patterns that look automated
SESSION_LAUNCH_DELAY_MIN=5
SESSION_LAUNCH_DELAY_MAX=30


# ─────────────────────────────────────────────────────────────────────────────
#  SECTION 3: DEVICE & BROWSER FINGERPRINT
# ─────────────────────────────────────────────────────────────────────────────

# Allowed device profiles (comma-separated)
# Options: win10, win11, macos_intel, macos_arm, linux, android, ios
# SessionEngine picks one randomly per session
ALLOWED_DEVICES=win10,win11

# Viewport randomization range (pixels)
# Real users have varying screen sizes. These set the randomization bounds.
VIEWPORT_WIDTH_MIN=1280
VIEWPORT_WIDTH_MAX=1920
VIEWPORT_HEIGHT_MIN=720
VIEWPORT_HEIGHT_MAX=1080

# User-Agent rotation (true/false)
# If true, rotates UA strings from a curated realistic pool
ROTATE_USER_AGENT=true


# ─────────────────────────────────────────────────────────────────────────────
#  SECTION 4: TRAFFIC VOLUME
# ─────────────────────────────────────────────────────────────────────────────

# Target total sessions to generate per run
TARGET_TRAFFIC_MIN=2000
TARGET_TRAFFIC_MAX=6000

# Traffic distribution across 24 hours (timezone-aware)
# "uniform" = flat distribution across all hours
# "realistic" = peaks at 9-11am and 7-9pm, low at 2-5am
# "business" = peaks at 9am-5pm, minimal outside office hours
TRAFFIC_DISTRIBUTION=realistic

# Timezone for traffic distribution curve
TRAFFIC_TIMEZONE=Asia/Jakarta


# ─────────────────────────────────────────────────────────────────────────────
#  SECTION 5: TARGET URL CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────

# Primary target URL (the landing page for each session)
TARGET_URL=https://example.com

# Internal URLs that get click priority (comma-separated)
# These are pages you want the bot to visit more often (e.g., from a DB)
# Leave empty to let the engine discover links organically
TARGET_INTERNAL_URLS=

# Domain blacklist — never click links to these domains (comma-separated)
BLACKLIST_DOMAINS=facebook.com,twitter.com,instagram.com,youtube.com,google.com,ads.google.com

# External link blacklist patterns (comma-separated, substring match)
BLACKLIST_URL_PATTERNS=login,signup,checkout,cart,admin,wp-admin


# ─────────────────────────────────────────────────────────────────────────────
#  SECTION 6: DWELL TIME (Weibull Model — Bab 2 §4, Bab 3 §Step C)
# ─────────────────────────────────────────────────────────────────────────────
#
#  Dwell time follows: T ~ Weibull(k, λ)
#
#  k < 1 produces "negative aging" (leave quick or stay long)
#  which matches NNg's observed dwell-time patterns.
#
#  Mean: E[T] = λ · Γ(1 + 1/k)
#
#  Default calibration: k=0.6, λ=35.9 → E[T]=54s, median≈19.5s
#  This matches Contentsquare benchmark (54s mean time on page)
#  and NNg observation (most users leave in 10-20s).
#
#  NOTE: These are BASE values. Persona attention multiplier
#  and frustration state modify the effective λ per session.
#  Mode presets may override these entirely.
#

# Weibull shape parameter (k < 1 = negative aging)
DWELL_WEIBULL_K=0.6

# Weibull scale parameter (λ, in seconds)
DWELL_WEIBULL_LAMBDA=35.9

# Minimum dwell time per page (seconds) — floor clamp
DWELL_MIN_SEC=2

# Maximum dwell time per page (seconds) — ceiling clamp
DWELL_MAX_SEC=300

# Bounce session dwell: uses separate Weibull with higher hazard
# k < 0.6 means bouncers leave even faster
BOUNCE_DWELL_WEIBULL_K=0.5
BOUNCE_DWELL_LAMBDA=4.0
BOUNCE_DWELL_MAX_SEC=30


# ─────────────────────────────────────────────────────────────────────────────
#  SECTION 7: BOUNCE RATE (Bab 1 §Node 2, Bab 3 §Step A)
# ─────────────────────────────────────────────────────────────────────────────
#
#  Base bounce rate = 47% (Contentsquare all-industry average).
#  Frustrated sessions get +7% uplift → effective ≈49%.
#
#  P(bounce) = min(BOUNCE_CEILING, base + frustration_uplift)
#
#  Modes override this:
#    Mode 2 (High Bounce):  85%
#    Mode 5 (Deep Reader):  15%
#    Mode 7 (SEO Boost):    20%
#

# Base bounce probability (0.0 - 1.0)
BOUNCE_RATE_BASE=0.47

# Frustration uplift to bounce rate (added when persona is frustrated)
BOUNCE_FRUSTRATION_UPLIFT=0.07

# Maximum effective bounce rate (ceiling)
BOUNCE_RATE_CEILING=0.85


# ─────────────────────────────────────────────────────────────────────────────
#  SECTION 8: PAGE COUNT PER SESSION (Bab 1 §3B, Bab 3 §Step A)
# ─────────────────────────────────────────────────────────────────────────────
#
#  For non-bounce sessions, page count follows:
#    P(N=n | not bounce) = p_stop × (1 - p_stop)^(n-2),  n ≥ 2
#
#  Calibrated so E[N] = 5 (Contentsquare benchmark):
#    p_stop = 0.53 / (5 - 1) = 0.1325
#
#  After user passes page 1 (not bounced), each subsequent page
#  has a 13.25% chance of being the last one.
#

# Per-page stop probability for geometric distribution
PAGE_STOP_PROBABILITY=0.1325

# Maximum pages per session (hard cap)
MAX_PAGES_PER_SESSION=50

# Mean dwell time for bounce sessions (seconds)
# Used by DwellWeibull.generateBounceDwell()
# Mode 6 default: 8.0s, Mode 2: 5.0s, Mode 7: 4.0s
# Set -1 to use mode default
BOUNCE_DWELL_MEAN=-1


# ─────────────────────────────────────────────────────────────────────────────
#  SECTION 9: SCROLL BEHAVIOR (Markov Chain — Bab 1 §3A, Bab 3 §Step D)
# ─────────────────────────────────────────────────────────────────────────────
#
#  Scroll depth uses an absorbing Markov chain with 5 segments:
#    S1=[0-20%] → S2=[20-40%] → S3=[40-60%] → S4=[60-80%] → S5=[80-100%]
#
#  Transition probabilities (scroll-forward from segment i):
#    r1=0.80, r2=0.73, r3=0.61, r4=0.28
#
#  Calibrated to: E[depth] = 56.8% (Contentsquare scroll rate)
#
#  CTMC holding times use NNg attention weights:
#    w1=0.57, w2=0.17, w3=0.13, w4=0.07, w5=0.06
#    (57% time above fold, 74% in first two screenfuls)
#

# Markov transition probabilities (scroll forward from each segment)
SCROLL_MARKOV_R1=0.80
SCROLL_MARKOV_R2=0.73
SCROLL_MARKOV_R3=0.61
SCROLL_MARKOV_R4=0.28

# Probability of scrolling UP (re-read) per scroll action
# Set -1 to use mode default
SCROLL_UP_PROBABILITY=-1

# Variance in scroll step size (0=uniform, 0.5=very variable)
# Set -1 to use mode default
SCROLL_SPEED_VARIANCE=-1

# CTMC attention weights per segment (must sum to 1.0)
# w1+w2 = 0.74 (NNg: 74% in first 2 screenfuls)
SCROLL_ATTENTION_W1=0.57
SCROLL_ATTENTION_W2=0.17
SCROLL_ATTENTION_W3=0.13
SCROLL_ATTENTION_W4=0.07
SCROLL_ATTENTION_W5=0.06


# ─────────────────────────────────────────────────────────────────────────────
#  SECTION 10: CLICK PROBABILITIES
# ─────────────────────────────────────────────────────────────────────────────
#
#  Click chances are PER ACTION SLICE (every ~2-3 seconds).
#  They are NOT per-page or per-session.
#
#  Internal clicks: navigate within the same domain
#  External clicks: navigate to a different domain (triggers lock)
#
#  Mode overrides:
#    Mode 2 (Bounce):    internal=0.00, external=0.00 (no clicks)
#    Mode 5 (Deep):      internal=0.008, external=0.001
#    Mode 7 (SEO Boost): internal=0.010, external=0.005
#

# Internal link click probability per action slice
CHANCE_CLICK_INTERNAL=0.004

# External link click probability per action slice
CHANCE_CLICK_EXTERNAL=0.0025

# Ad click CTR per interaction cycle (~1% benchmark, Google AdSense)
# Set -1 to use mode default
CHANCE_CLICK_AD=-1

# Priority weight for DB-known target URLs (0.0=random, 1.0=always DB)
# Set -1 to use mode default
CLICK_INTERNAL_DB_PRIORITY=-1


# ─────────────────────────────────────────────────────────────────────────────
#  SECTION 11: COOKIE CONSENT (CHB 2025 + etracker — Bab 1 §Node 1, Bab 3 §F)
# ─────────────────────────────────────────────────────────────────────────────
#
#  Cookie persona types from CHB 2025:
#    AA (Always Accept)  — clicks accept fast, no reading
#    AR (Always Reject)  — looks for reject/settings
#    CTX (Contextual)    — reads options, depends on banner design
#
#  P(stable = AA or AR) = 2/3 (CHB 2025)
#  P(contextual = CTX)  = 1/3
#
#  Decomposition calibrated to overall P(accept) = 0.40:
#    P(AA)=0.28, P(AR)=0.39, P(CTX)=0.33
#    P(accept|CTX) = 0.36
#
#  Timing: AA=1.5-3s, AR=2-5s, CTX=4-8s
#

# Overall cookie accept rate (etracker 2025: 40%)
# Set -1 to use mode default
COOKIE_ACCEPT_RATE=-1

# Stable preference ratio (CHB 2025: ~2/3 consistent)
# Set -1 to use mode default
COOKIE_STABLE_RATIO=-1

# Reaction delay before cookie banner interaction (ms)
# Set -1 to use mode default
COOKIE_REACTION_DELAY_MIN=-1
COOKIE_REACTION_DELAY_MAX=-1

# Cookie persona distribution (must sum to 1.0)
COOKIE_PROB_AA=0.28
COOKIE_PROB_AR=0.39
COOKIE_PROB_CTX=0.33

# P(accept) for contextual users (AA=1.0, AR=0.0 always)
COOKIE_CTX_ACCEPT_RATE=0.36

# Reaction time ranges per type (milliseconds)
COOKIE_AA_DELAY_MIN=1500
COOKIE_AA_DELAY_MAX=3000
COOKIE_AR_DELAY_MIN=2000
COOKIE_AR_DELAY_MAX=5000
COOKIE_CTX_DELAY_MIN=4000
COOKIE_CTX_DELAY_MAX=8000


# ─────────────────────────────────────────────────────────────────────────────
#  SECTION 12: POPUP HANDLING (Omnisend 2025 — Bab 1 §Node 4, Bab 3 §E)
# ─────────────────────────────────────────────────────────────────────────────
#
#  Popup conversion rates by delay (Omnisend benchmark):
#    0-1s:   1.9%       6-10s:  2.4% (sweet spot)
#    1-5s:   2.3%       11-15s: 2.1%
#    16-30s: 1.9%       31-60s: 1.8%
#
#  Response distribution for shown popups:
#    convert: per Omnisend rate
#    close:   ~75%
#    ignore:  ~23-24% (remainder)
#

# Expected popup delay on target site (seconds, 0 = no popup expected)
POPUP_EXPECTED_DELAY_SEC=8

# Override conversion rate (0 = use Omnisend benchmarks automatically)
POPUP_CONVERSION_OVERRIDE=0

# Popup close probability (of non-convert responses)
POPUP_CLOSE_RATE=0.75

# Whether popup conversion is allowed
POPUP_CONVERT_ENABLED=true

# Popup ignore rate: P(ignore) = 1 - close - convert
# Set -1 to use mode default
POPUP_IGNORE_RATE=-1

# Browser popup tab follow chance
# < 30s elapsed: use low value; > 30s elapsed: use high value
POPUP_TAB_FOLLOW_EARLY=0.05
POPUP_TAB_FOLLOW_LATE=0.20


# ─────────────────────────────────────────────────────────────────────────────
#  SECTION 13: FRUSTRATION MODEL (Contentsquare 2024 — Bab 1 §E, Bab 3 §B)
# ─────────────────────────────────────────────────────────────────────────────
#
#  39.6% of sessions are "marred by frustration" (Contentsquare).
#  Frustration effects:
#    - Shorter dwell (×0.65 multiplier on Weibull λ)
#    - Higher bounce (+7% uplift)
#    - Rage clicks enabled (3+ clicks in <2s)
#    - Faster overlay dismissal
#

# Base frustration probability
FRUSTRATION_RATE=0.396

# Dwell time multiplier for frustrated sessions (< 1.0 = shorter)
FRUSTRATION_DWELL_MULTIPLIER=0.65

# Bounce rate uplift for frustrated sessions
FRUSTRATION_BOUNCE_UPLIFT=0.07

# Per-cycle rage click chance when frustrated
# Set -1 to use mode default
RAGE_CLICK_CHANCE=-1

# Rage click parameters (only for frustrated personas)
RAGE_CLICK_MIN=3
RAGE_CLICK_MAX=6
RAGE_CLICK_INTERVAL_MIN_MS=80
RAGE_CLICK_INTERVAL_MAX_MS=250


# ─────────────────────────────────────────────────────────────────────────────
#  SECTION 14: MICRO-HABIT PROBABILITIES
# ─────────────────────────────────────────────────────────────────────────────
#
#  Idle fidget distribution (sub-conscious micro-behaviors):
#    cursorDrift:  40%   briefSelect: 15%   nothing:    10%
#    microScroll:  25%   cursorPark:  10%
#
#  Overlay dismiss strategy:
#    close-button: 75%   escape: 15%   backdrop: 10%
#
#  Tab switch away duration:
#    quick (3-8s):    60%
#    read (8-20s):    30%
#    extended (20-60s): 10%
#

# ——— Per-cycle micro-interaction probabilities (ModePresets ENV_MAP) ———
# Set -1 to use mode default.

CHANCE_TEXT_SELECT=-1
CHANCE_IDLE_PAUSE=-1
IDLE_PAUSE_MIN_MS=-1
IDLE_PAUSE_MAX_MS=-1
CHANCE_TAB_SWITCH=-1
TAB_SWITCH_AWAY_MIN_MS=-1
TAB_SWITCH_AWAY_MAX_MS=-1
CHANCE_MOUSE_DRIFT=-1
CHANCE_HOVER_ELEMENT=-1

# ——— Fidget weights (internal distribution, not per-cycle) ———
# Fidget weights (must sum to 1.0)
FIDGET_CURSOR_DRIFT=0.40
FIDGET_MICRO_SCROLL=0.25
FIDGET_BRIEF_SELECT=0.15
FIDGET_CURSOR_PARK=0.10
FIDGET_NOTHING=0.10

# Overlay dismiss strategy weights (must sum to 1.0)
OVERLAY_CLOSE_BUTTON=0.75
OVERLAY_ESCAPE_KEY=0.15
OVERLAY_BACKDROP_CLICK=0.10

# Tab switch away duration weights (must sum to 1.0)
TAB_SWITCH_QUICK=0.60
TAB_SWITCH_READ=0.30
TAB_SWITCH_EXTENDED=0.10

# Tab switch duration ranges (milliseconds)
TAB_SWITCH_QUICK_MIN=3000
TAB_SWITCH_QUICK_MAX=8000
TAB_SWITCH_READ_MIN=8000
TAB_SWITCH_READ_MAX=20000
TAB_SWITCH_EXTENDED_MIN=20000
TAB_SWITCH_EXTENDED_MAX=60000


# ─────────────────────────────────────────────────────────────────────────────
#  SECTION 15: HOVER EXPLORATION WEIGHTS
# ─────────────────────────────────────────────────────────────────────────────
#
#  Element interest weights for hover targeting.
#  Higher weight = more likely to attract mouse hover.
#  (Do NOT need to sum to 1.0 — they are normalized internally)
#

HOVER_WEIGHT_LINKS=0.30
HOVER_WEIGHT_BUTTONS=0.15
HOVER_WEIGHT_IMAGES=0.20
HOVER_WEIGHT_HEADINGS=0.15
HOVER_WEIGHT_PARAGRAPHS=0.10
HOVER_WEIGHT_INPUTS=0.05
HOVER_WEIGHT_VIDEOS=0.05


# ─────────────────────────────────────────────────────────────────────────────
#  SECTION 15B: READING & ATTENTION SIMULATION
# ─────────────────────────────────────────────────────────────────────────────
#
#  F-pattern reading + attention decay (Brysbaert 2019: 238 wpm)
#  Set -1 to use mode default.
#

# W8 FIX: Explicit reading speed with std dev for per-session variance
# Brysbaert 2019: mean=238wpm, std=50wpm (individual differences are large)
READING_SPEED_WPM=-1
READING_SPEED_STD=-1
SCAN_FACTOR_MIN=-1
SCAN_FACTOR_MAX=-1
F_PATTERN_ENABLED=true


# ─────────────────────────────────────────────────────────────────────────────
#  SECTION 16: MOUSE PHYSICS
# ─────────────────────────────────────────────────────────────────────────────
#
#  Bézier curve mouse movement with overshoot correction.
#  These control the "feel" of mouse movements.
#

# Bézier curve steps (higher = smoother but slower)
# Fitts's Law parameters (MT = a + b × log2(D/W + 1))
# Set -1 to use mode default
FITTS_A=-1
FITTS_B=-1

# Bézier curve steps (higher = smoother)
# W5 FIX: Wider range for more natural per-session variance
MOUSE_BEZIER_STEPS_MIN=12
MOUSE_BEZIER_STEPS_MAX=50

# Overshoot probability and distance
# W5 FIX: Wider overshoot range for per-worker distinctness
MOUSE_OVERSHOOT_CHANCE=0.30
MOUSE_OVERSHOOT_PIXELS_MIN=3
MOUSE_OVERSHOOT_PIXELS_MAX=28

# Gaussian hand tremor σ (px)
# W4 FIX: Explicit range for per-worker variance
# Mode default applies per-persona randomization on top
MOUSE_JITTER_STD=-1

# Inter-step delay between mouse position updates (ms)
# Set -1 to use mode default
MOUSE_STEP_DELAY_MIN=-1
MOUSE_STEP_DELAY_MAX=-1

# Network jitter simulation (ms) — simulates latency variance
NETWORK_JITTER_MIN=50
NETWORK_JITTER_MAX=200


# ─────────────────────────────────────────────────────────────────────────────
#  SECTION 17: PERSONA GENERATION
# ─────────────────────────────────────────────────────────────────────────────
#
#  Persona attention multiplier: Gaussian(μ=1.0, σ=0.15)
#  This creates natural variance in browsing depth/speed.
#  Value > 1.0 = more attentive (longer dwell, deeper scroll)
#  Value < 1.0 = less attentive (shorter dwell, shallow scroll)
#

# Attention multiplier distribution
PERSONA_ATTENTION_MEAN=1.0
PERSONA_ATTENTION_STDDEV=0.15
PERSONA_ATTENTION_MIN=0.5
PERSONA_ATTENTION_MAX=2.0

# Scroll style distribution (must sum to 1.0)
# wheel: standard mouse wheel scrolling
# keyboard: ArrowDown/PageDown/Space
# mixed: alternates between methods
PERSONA_SCROLL_WHEEL=0.60
PERSONA_SCROLL_KEYBOARD=0.15
PERSONA_SCROLL_MIXED=0.25


# ─────────────────────────────────────────────────────────────────────────────
#  SECTION 18: POST-CONVERSION (External Click Lock)
# ─────────────────────────────────────────────────────────────────────────────
#
#  After clicking an external link (conversion), the session enters
#  "locked" mode. The bot idles on the external page briefly before
#  ending the session. This prevents unnatural abrupt exits.
#

# Post-conversion idle duration (milliseconds)
POST_CONVERSION_IDLE_MIN=10000
POST_CONVERSION_IDLE_MAX=30000

# Post-conversion behavior distribution (must sum to 1.0)
POST_CONV_SCROLL=0.60
POST_CONV_MICRO_HABIT=0.25
POST_CONV_WAIT=0.15


# ─────────────────────────────────────────────────────────────────────────────
#  SECTION 19: NNg PHASE BOUNDARIES (seconds)
# ─────────────────────────────────────────────────────────────────────────────
#
#  NNg research divides page visit into 3 phases:
#    critical (0 - 10s): user decides to stay or leave
#    decision (10 - 30s): user scans content, decides engagement level
#    committed (30s+): user is reading thoroughly
#
#  These boundaries affect which micro-habits are executed.
#  In critical phase: no clicks, mostly orientation (hover, overlay)
#  In decision phase: scanning scroll, hover exploration
#  In committed phase: deep reading, text select, tab switch
#

NNG_CRITICAL_END_SEC=10
NNG_DECISION_END_SEC=30


# ─────────────────────────────────────────────────────────────────────────────
#  SECTION 20: LOGGING & DEBUG
# ─────────────────────────────────────────────────────────────────────────────

# Enable debug logging (true/false)
# Outputs detailed per-action logs to console
DEBUG=false

# Enable entropy tracking (true/false)
# Tracks randomness distribution for audit/verification
ENTROPY_TRACKING=false

# Log file path (empty = console only)
LOG_FILE=

# Event log format: "json" or "csv"
EVENT_LOG_FORMAT=json


# ─────────────────────────────────────────────────────────────────────────────
#  SECTION 18B: EXTERNAL CLICK LOCK (Session behavior after external click)
# ─────────────────────────────────────────────────────────────────────────────
#
#  After clicking an external link, session enters "locked" mode.
#  Set -1 to use mode default.
#

EXTERNAL_CLICK_LOCK=true
EXTERNAL_IDLE_SCROLL_CHANCE=-1
EXTERNAL_MAX_TIME_SEC=-1


# ╔═══════════════════════════════════════════════════════════════════════════════╗
# ║  QUICK REFERENCE — MODE DEFAULTS (from ModePresets.js v1.3.0)              ║
# ╠═══════════════════════════════════════════════════════════════════════════════╣
# ║                                                                             ║
# ║  Parameter          │ Mode2 │ Mode3 │ Mode4 │ Mode5 │ Mode6 │ Mode7        ║
# ║  ───────────────────┼───────┼───────┼───────┼───────┼───────┼───────       ║
# ║  BOUNCE_RATE_BASE   │ 0.85  │ 0.47  │ 0.20  │ 0.10  │ 0.47  │ 0.65        ║
# ║  PAGE_STOP_PROB     │ 0.40  │ 0.265 │ 0.133 │ 0.082 │ 0.133 │ 0.50        ║
# ║  DWELL_WEIBULL_K    │ 0.50  │ 0.55  │ 0.65  │ 0.70  │ 0.60  │ 0.45        ║
# ║  DWELL_WEIBULL_λ    │ 8.0   │ 20.0  │ 50.0  │ 65.0  │ 35.9  │ 10.0        ║
# ║  E[T] (mean dwell)  │ ~16s  │ ~34s  │ ~68s  │ ~82s  │ 54s   │ ~25s        ║
# ║  CLICK_INTERNAL     │ 0.001 │ 0.006 │ 0.015 │ 0.030 │ 0.008 │ 0.002       ║
# ║  CLICK_EXTERNAL     │ 0.001 │ 0.003 │ 0.005 │ 0.008 │ 0.004 │ 0.001       ║
# ║  SCROLL_R1          │ 0.40  │ 0.65  │ 0.88  │ 0.93  │ 0.80  │ 0.50        ║
# ║  E[scroll_depth]    │ ~30%  │ ~43%  │ ~68%  │ ~80%  │ 57%   │ ~34%        ║
